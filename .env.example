# Elasticsearch credentials and URL
ELASTIC_PASSWORD=changeme
ELASTICSEARCH_URL=http://localhost:9200

# Kibana URL
KIBANA_URL=http://localhost:5601

# Anthropic API key and model configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model to use for AI enrichment (sourced here, referenced via settings.anthropic_model)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Logging level for the enrichment service
LOG_LEVEL=info

# Feature flags
# Enable writing analyst feedback to Elasticsearch
ENABLE_FEEDBACK_LOOP=true
# Enable VirusTotal IOC lookups
ENABLE_VIRUSTOTAL=false
# Enable AbuseIPDB IOC lookups
ENABLE_ABUSEIPDB=false

# VirusTotal API key (required if ENABLE_VIRUSTOTAL=true)
VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (required if ENABLE_ABUSEIPDB=true)
ABUSEIPDB_API_KEY=
